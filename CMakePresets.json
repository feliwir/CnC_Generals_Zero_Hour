{
    "version": 6,
    "configurePresets": [
        {
            "name": "default",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake"
            }
        },
        {
            "name": "debug",
            "inherits": [
                "default"
            ],
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "VCPKG_BUILD_TYPE": "debug"
            }
        },
        {
            "name": "release",
            "inherits": [
                "default"
            ],
            "hidden": true,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "VCPKG_BUILD_TYPE": "release",
                "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON"
            }
        },
        {
            "name": "sanitize",
            "inherits": [
                "debug"
            ],
            "hidden": true,
            "cacheVariables": {
                "SAGE_WITH_ASAN": "ON",
                "SAGE_WITH_UBSAN": "ON"
            }
        },
        {
            "name": "macos-arm64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "arm64-osx-dynamic"
            }
        },
        {
            "name": "linux-x64",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "VCPKG_TARGET_TRIPLET": "x64-linux-dynamic"
            }
        },
        {
            "name": "macos-arm64-debug",
            "inherits": [
                "macos-arm64",
                "debug"
            ]
        },
        {
            "name": "linux-x64-debug",
            "inherits": [
                "linux-x64",
                "debug"
            ]
        },
        {
            "name": "linux-x64-release",
            "inherits": [
                "linux-x64",
                "release"
            ]
        },
        {
            "name": "linux-x64-sanitize",
            "inherits": [
                "linux-x64",
                "sanitize"
            ]
        }
    ],
    "buildPresets": [
        {
            "name": "macos-arm64-debug",
            "configurePreset": "macos-arm64-debug"
        },
        {
            "name": "linux-x64-debug",
            "configurePreset": "linux-x64-debug"
        },
        {
            "name": "linux-x64-release",
            "configurePreset": "linux-x64-release"
        },
        {
            "name": "linux-x64-sanitize",
            "configurePreset": "linux-x64-sanitize"
        }
    ]
}